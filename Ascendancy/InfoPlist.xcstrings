    "NSHealthShareUsageDescription" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "يستخدم Ascendancy تطبيق صحة Apple لعرض مقاييس صحتك في مكان واحد."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ascendancy nutzt Apple Health, um deine Gesundheitsmetriken an einem Ort anzuzeigen."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ascendancy usa Apple Salud para mostrar tus métricas de salud en un solo lugar."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ascendancy utilise Santé pour afficher vos indicateurs de santé au même endroit."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ascendancy आपके स्वास्थ्य मेट्रिक्स एक जगह दिखाने के लिए Apple Health का उपयोग करता है।"
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ascendancy usa Salute per mostrare le tue metriche sanitarie in un unico posto."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "AscendancyはAppleヘルスケアを使って健康指標をまとめて表示します。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ascendancy는 Apple 건강을 사용해 건강 지표를 한곳에 표시합니다."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ascendancy gebruikt Apple Gezondheid om je gezondheidsgegevens op één plek te tonen."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ascendancy korzysta z Apple Health, aby wyświetlać Twoje dane zdrowotne w jednym miejscu."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "O Ascendancy usa o Apple Saúde para exibir suas métricas de saúde em um só lugar."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ascendancy использует «Здоровье» Apple для отображения показателей здоровья в одном месте."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ascendancy, sağlık ölçümlerinizi tek yerde göstermek için Apple Sağlık’ı kullanır."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ascendancy 使用“健康”在一处显示你的健康指标。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ascendancy 使用「健康」在同一處顯示你的健康指標。"
          }
        }
      }
    },
    "NSHealthUpdateUsageDescription" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "قد يكتب Ascendancy بيانات صحية لتتبع تقدمك."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ascendancy kann Gesundheitsdaten schreiben, um deinen Fortschritt zu verfolgen."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ascendancy puede escribir datos de salud para ayudarte a seguir tu progreso."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ascendancy peut enregistrer des données de santé pour suivre vos progrès."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "प्रगति ट्रैक करने में मदद के लिए Ascendancy स्वास्थ्य डेटा लिख सकता है।"
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ascendancy può scrivere dati sanitari per seguire i tuoi progressi."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "進捗の記録のために健康データを書き込む場合があります。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "진행 상황 추적을 위해 건강 데이터를 기록할 수 있습니다."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ascendancy kan gezondheidsgegevens schrijven om je voortgang bij te houden."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ascendancy może zapisywać dane zdrowotne, aby śledzić postępy."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "O Ascendancy pode gravar dados de saúde para acompanhar seu progresso."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ascendancy может записывать данные о здоровье для отслеживания прогресса."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ascendancy, ilerlemenizi takip etmek için sağlık verisi yazabilir."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ascendancy 可能会写入健康数据以帮助记录进展。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ascendancy 可能會寫入健康資料以協助追蹤進度。"
          }
        }
      }
    }
  },
  "version" : "1.0"
}