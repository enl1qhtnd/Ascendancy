    "Allow Ascendancy to read your health data for metrics and insights.": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Erlaube Ascendancy, Gesundheitsdaten für Metriken zu lesen."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Permite que Ascendancy lea tus datos de salud para métricas."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Autorisez Ascendancy à lire vos données de santé pour les mesures."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Consenti ad Ascendancy di leggere i dati salute per le metriche."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "メトリクス用にヘルスケアデータの読み取りを許可します。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "지표를 위해 건강 데이터 읽기를 허용합니다."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "允许 Ascendancy 读取健康数据以显示指标。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "允許 Ascendancy 讀取健康資料以顯示指標。"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Allow Ascendancy to read your health data for metrics and insights."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Разрешить Ascendancy читать данные «Здоровья» для показателей."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "اسمح لـ Ascendancy بقراءة بيانات الصحة للمقاييس."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "मेट्रिक्स के लिए Ascendancy को स्वास्थ्य डेटा पढ़ने दें।"
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Sta Ascendancy toe gezondheidsgegevens te lezen voor metriek."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Zezwól Ascendancy na odczyt danych zdrowotnych dla metryk."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Metrikler için Ascendancy’nin sağlık verilerinizi okumasına izin verin."
          }
        }
      }
    },
