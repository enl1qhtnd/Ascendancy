    "This will permanently delete this protocol and all %lld logged doses. This cannot be undone." : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "سيؤدي هذا إلى حذف هذا البروتوكول نهائيًا وجميع جرعات %lld المسجلة. لا يمكن التراجع عن هذا."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dies löscht dieses Protokoll und alle %lld protokollierten Dosen dauerhaft. Das kann nicht rückgängig gemacht werden."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Esto eliminará permanentemente este protocolo y las %lld dosis registradas. No se puede deshacer."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cela supprimera définitivement ce protocole et les %lld doses enregistrées. Action irréversible."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "यह इस प्रोटोकॉल और सभी %lld लॉग खुराक को स्थायी रूप से हटा देगा। इसे असंपादित नहीं किया जा सकता है।"
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Eliminerà definitivamente questo protocollo e le %lld dosi registrate. Operazione irreversibile."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "これにより、このプロトコルと %lld に記録されたすべての用量が完全に削除されます。これを元に戻すことはできません。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "이렇게 하면 이 프로토콜과 %lld에 기록된 모든 복용량이 영구적으로 삭제됩니다. 이 작업은 취소할 수 없습니다."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hierdoor worden dit protocol en alle %lld geregistreerde doses permanent verwijderd. Dit kan niet ongedaan worden gemaakt."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Spowoduje to trwałe usunięcie tego protokołu i wszystkich zarejestrowanych dawek %lld. Tego nie można cofnąć."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Isso excluirá permanentemente este protocolo e todas as doses registradas do %lld. Isto não pode ser desfeito."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Это приведет к безвозвратному удалению этого протокола и всех зарегистрированных доз %lld. Это невозможно отменить."
          }
        },
