    "Tap + to add protocol photos,\nbloodwork results, or documents." : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "اضغط على + لإضافة صور البروتوكول،\nنتائج تحاليل الدم، أو المستندات."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tippe auf +, um Fotos, Laborwerte oder Dokumente hinzuzufügen."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Toca + para añadir fotos, analíticas o documentos."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Appuyez sur + pour ajouter photos, analyses ou documents."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "प्रोटोकॉल फ़ोटो जोड़ने के लिए + टैप करें,\nरक्तकार्य परिणाम, या दस्तावेज़।"
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tocca + per aggiungere foto, esami o documenti."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "+ をタップしてプロトコル写真を追加します。\n血液検査の結果や書類。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "프로토콜 사진을 추가하려면 +를 탭하세요.\n혈액 검사 결과 또는 문서."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tik op + om protocolfoto's toe te voegen,\nbloedonderzoekresultaten of documenten."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Stuknij +, aby dodać zdjęcia protokołu,\nwyniki badań krwi lub dokumenty."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Toque em + para adicionar fotos de protocolo,\nresultados de exames de sangue ou documentos."
