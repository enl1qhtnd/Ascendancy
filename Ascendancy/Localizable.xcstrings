    "Track your next scheduled dose, today's progress, and low inventory from the Home Screen." : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "تتبع جرعتك المجدولة التالية، والتقدم المحرز اليوم، والمخزون المنخفض من الشاشة الرئيسية."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Verfolge deine nächste geplante Dosis, den heutigen Fortschritt und niedrige Bestände vom Home-Bildschirm."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sigue tu próxima dosis programada, el progreso de hoy y el inventario bajo desde la pantalla de inicio."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Suivez votre prochaine dose prévue, la progression du jour et les stocks faibles depuis l’écran d’accueil."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "होम स्क्रीन से अपनी अगली निर्धारित खुराक, आज की प्रगति और कम इन्वेंट्री को ट्रैक करें।"
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tieni traccia della prossima dose programmata, dei progressi di oggi e delle scorte basse dalla schermata Home."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ホーム画面から、次回の予定投与量、今日の進捗状況、残りの在庫状況を追跡します。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "홈 화면에서 다음 예정된 복용량, 오늘의 진행 상황 및 재고 부족을 추적하세요."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Volg uw volgende geplande dosis, de voortgang van vandaag en de lage voorraad vanaf het startscherm."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Śledź następną zaplanowaną dawkę, dzisiejszy postęp i niski poziom zapasów na ekranie głównym."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Acompanhe sua próxima dose programada, o progresso de hoje e o estoque baixo na tela inicial."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Отслеживайте следующую запланированную дозу, сегодняшний прогресс и низкий уровень запасов на главном экране."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bir sonraki planlanmış dozunuzu, bugünkü ilerlemenizi ve düşük envanterinizi Ana Ekrandan takip edin."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "从主屏幕跟踪您的下一个预定剂量、今天的进度和低库存。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "從主螢幕追蹤您的下一個預定劑量、今天的進度和低庫存。"
          }
        }
      }
    },
