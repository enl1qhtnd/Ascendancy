    "This replaces protocols, logs, files, and profile settings. iCloud Sync may apply these changes on your other devices." : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "يحل هذا محل البروتوكولات والسجلات والملفات وإعدادات ملف التعريف. قد تقوم iCloud Sync بتطبيق هذه التغييرات على أجهزتك الأخرى."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dies ersetzt Protokolle, Einträge, Dateien und Profileinstellungen. iCloud-Sync kann diese Änderungen auf deine anderen Geräte übertragen."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Esto reemplaza protocolos, registros, archivos y ajustes de perfil. La sincronización de iCloud puede aplicar estos cambios en tus otros dispositivos."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cela remplace les protocoles, journaux, fichiers et réglages du profil. La synchronisation iCloud peut appliquer ces changements sur vos autres appareils."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "यह प्रोटोकॉल, लॉग, फ़ाइलें और प्रोफ़ाइल सेटिंग्स को प्रतिस्थापित करता है। iCloud सिंक इन परिवर्तनों को आपके अन्य डिवाइस पर लागू कर सकता है।"
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sostituisce protocolli, registri, file e impostazioni del profilo. La sincronizzazione iCloud può applicare queste modifiche sugli altri dispositivi."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "これにより、プロトコル、ログ、ファイル、プロファイル設定が置き換えられます。 iCloud 同期により、これらの変更が他のデバイスに適用される場合があります。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "이는 프로토콜, 로그, 파일 및 프로필 설정을 대체합니다. iCloud 동기화는 이러한 변경 사항을 다른 기기에 적용할 수 있습니다."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dit vervangt protocollen, logs, bestanden en profielinstellingen. iCloud Sync kan deze wijzigingen toepassen op uw andere apparaten."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Zastępuje to protokoły, dzienniki, pliki i ustawienia profili. iCloud Sync może zastosować te zmiany na innych Twoich urządzeniach."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Isso substitui protocolos, logs, arquivos e configurações de perfil. O iCloud Sync pode aplicar essas alterações em seus outros dispositivos."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Это заменяет протоколы, журналы, файлы и настройки профиля. iCloud Sync может применить эти изменения на других ваших устройствах."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bu, protokollerin, günlüklerin, dosyaların ve profil ayarlarının yerini alır. iCloud Sync bu değişiklikleri diğer aygıtlarınıza da uygulayabilir."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "这取代了协议、日志、文件和配置文件设置。 iCloud 同步可能会将这些更改应用到您的其他设备上。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "這取代了協定、日誌、檔案和設定檔設定。 iCloud 同步可能會將這些變更套用到您的其他裝置上。"
          }
        }
      }
    },
